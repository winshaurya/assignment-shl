# API keys for Gemini LLM integration.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Data paths
ASSESSMENTS_JSON=data/assessments.json
FAISS_INDEX_DIR=data/faiss_index

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval tuning
SEMANTIC_WEIGHT=0.7
KEYWORD_WEIGHT=0.3
TOP_K=10

# Server
LOG_LEVEL=INFO
